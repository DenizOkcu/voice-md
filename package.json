{
  "name": "obsidian-voice-md",
  "version": "1.2.6",
  "description": "Record audio and transcribe it to markdown using OpenAI Audio Transcription API",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "update-version": "node update-version.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "voice",
    "transcription",
    "gpt-4o-transcribe",
    "openai"
  ],
  "author": "Deniz Okcu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:DenizOkcu/voice-md.git"
  },
  "homepage": "https://github.com/DenizOkcu/voice-md#readme",
  "bugs": {
    "url": "https://github.com/DenizOkcu/voice-md/issues"
  },
  "dependencies": {
    "openai": "^6.37.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.7.0",

    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "globals": "^17.6.0",
    "obsidian": "^1.12.3",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
